# API Configuration for Capacitor Native Apps
#
# For iOS/Android native apps, you need to specify the full backend URL
# since they can't use relative URLs or Vite's proxy.
#
# Options:
# 1. Production server (works anywhere):
#    VITE_API_URL=http://65.0.132.181:8000
#
# 2. Local development - use your Mac's local IP address:
#    Find your Mac's IP: System Settings > Network > Wi-Fi > Details > TCP/IP
#    Example: VITE_API_URL=http://192.168.1.100:8000
#
# 3. For testing with Proxyman on iOS simulator:
#    Use your Mac's IP address and ensure Proxyman is configured to intercept traffic
#
# Note: Web builds ignore this and use relative URLs (proxied in dev, direct in prod)

VITE_API_URL=http://65.0.132.181:8000
